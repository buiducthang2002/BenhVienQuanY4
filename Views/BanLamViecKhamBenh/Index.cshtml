@model IEnumerable<APP.Models.BanLamViecKhamBenh>

@{
    ViewData["Title"] = "Ban làm việc khám bệnh";
}

<div class="container mt-4">
    <h4 class="page-title text-center mb-4">BÀN LÀM VIỆC KHÁM BỆNH</h4>

    <form asp-action="Index" method="get" class="d-flex justify-content-center align-items-center mb-3">
        <input type="text" name="makcb" value="@ViewBag.makcb" class="form-control me-2" style="max-width:300px;" placeholder="Nhập Mã KCB..." />
        <button type="submit" class="btn btn-danger">🔍 Tìm kiếm</button>
    </form>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-bordered table-hover text-center">
                <thead class="table-danger text-white">
                    <tr>
                        <th>Mã KCB</th>
                        <th>Mã khu khám</th>
                        <th>Mã phòng</th>
                        <th>Mã nhân viên</th>
                        <th>Ngày khám</th>
                        <th>Đã ký</th>
                        <th>Sửa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.makcb</td>
                            <td>@(item.makk?.ToString() ?? "N/A")</td>
                            <td>@(item.maphong?.ToString() ?? "N/A")</td>
                            <td>@(item.manv?.ToString() ?? "N/A")</td>
                            <td>@(item.ngay?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                            <td>@(string.IsNullOrEmpty(item.daky) ? "Chưa ký" : "Đã ký")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.makcb" class="btn btn-sm btn-warning">✏️ Sửa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (ViewBag.makcb != null)
    {
        <div class="alert alert-warning text-center">Không tìm thấy dữ liệu với Mã KCB này.</div>
    }
</div>

@model APP.Models.BanLamViecKhamBenh

@{
    ViewData["Title"] = "Sửa thông tin khám bệnh";
}

<div class="container mt-4" style="max-width:600px;">
    <h4 class="page-title text-center mb-4">SỬA THÔNG TIN KHÁM BỆNH</h4>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <input type="hidden" asp-for="makcb" />

        <div class="mb-3">
            <label asp-for="makcb" class="form-label fw-bold"></label>
            <input asp-for="makcb" class="form-control" readonly />
        </div>
        <div class="mb-3">
            <label asp-for="makk" class="form-label fw-bold"></label>
            <input asp-for="makk" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="maphong" class="form-label fw-bold"></label>
            <input asp-for="maphong" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="manv" class="form-label fw-bold"></label>
            <input asp-for="manv" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ngay" class="form-label fw-bold"></label>
            <input asp-for="ngay" type="datetime-local" class="form-control"
                   value="@(Model.ngay.HasValue ? Model.ngay.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
        </div>
        <div class="mb-3">
            <label asp-for="daky" class="form-label fw-bold"></label>
            <textarea asp-for="daky" class="form-control" rows="4"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">💾 Lưu</button>
            <a asp-action="Index" asp-route-makcb="@Model.makcb" class="btn btn-secondary">← Quay lại</a>
        </div>
    </form>
</div>

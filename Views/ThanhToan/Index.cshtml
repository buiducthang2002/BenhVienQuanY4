@model List<APP.Models.ThanhToanViewModel>
@{
    ViewData["Title"] = "Tra cứu thanh toán";
}

<style>
    .page-header-custom {
        padding: 20px 0;
        margin-bottom: 25px;
    }

    .page-header-custom h2 {
        color: #e91e63;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0;
    }

    .search-card-custom {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .search-card-custom .card-header {
        background: linear-gradient(135deg, #00bcd4 0%, #0097a7 100%);
        border-radius: 10px 10px 0 0 !important;
        padding: 15px 20px;
    }

    .btn-search-custom {
        background: linear-gradient(135deg, #e91e63 0%, #d81b60 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 10px 20px;
        border-radius: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 3px 6px rgba(233, 30, 99, 0.3);
    }

    .btn-search-custom:hover {
        background: linear-gradient(135deg, #d81b60 0%, #c2185b 100%);
        transform: translateY(-2px);
        box-shadow: 0 5px 10px rgba(233, 30, 99, 0.4);
        color: white;
    }

    .btn-save-custom {
        background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 10px 24px;
        border-radius: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 3px 6px rgba(76, 175, 80, 0.3);
    }

    .btn-save-custom:hover {
        background: linear-gradient(135deg, #388e3c 0%, #2e7d32 100%);
        transform: translateY(-2px);
        box-shadow: 0 5px 10px rgba(76, 175, 80, 0.4);
        color: white;
    }

    .data-table-custom {
        border: none;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.12);
    }

    .table-custom {
        margin-bottom: 0;
        font-size: 14px;
    }

    .table-custom thead {
        background: linear-gradient(135deg, #e91e63 0%, #d81b60 100%);
    }

    .table-custom thead th {
        color: white;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.5px;
        border: none;
        padding: 15px 10px;
        vertical-align: middle;
    }

    .table-custom tbody tr {
        transition: all 0.2s ease;
    }

    .table-custom tbody tr:hover {
        background-color: #fff3f8 !important;
        transform: scale(1.002);
    }

    .table-custom tbody td {
        vertical-align: middle;
        padding: 12px 10px;
        border-color: #ffe4f0;
    }

    .form-control:focus {
        border-color: #f48fb1;
        box-shadow: 0 0 0 0.2rem rgba(233, 30, 99, 0.25);
    }

    .input-custom {
        border: 2px solid #f8bbd0;
        border-radius: 6px;
        padding: 10px 15px;
        transition: all 0.3s ease;
    }

    .input-custom:focus {
        border-color: #e91e63;
        box-shadow: 0 0 0 0.2rem rgba(233, 30, 99, 0.15);
    }

    .edit-card-custom {
        border: none;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .edit-card-custom .card-header {
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        border-radius: 10px 10px 0 0 !important;
        padding: 15px 20px;
    }

    .form-label-custom {
        font-weight: 600;
        color: #555;
        font-size: 13px;
        margin-bottom: 4px;
    }

    .section-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #888;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 6px;
        margin-bottom: 12px;
    }

    .info-badge {
        display: inline-block;
        background: #e3f2fd;
        color: #1565c0;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 14px;
        font-weight: 600;
    }
</style>

<div class="container-fluid">
    <div class="page-header-custom text-center">
        <h2>
            🧾 TRA CỨU & CẬP NHẬT THANH TOÁN
        </h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>✅ Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>❌ Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Form tìm kiếm -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card search-card-custom">
                <div class="card-header text-white">
                    <h6 class="mb-0 fw-bold">🔍 TÌM KIẾM THEO SỐ PHIẾU</h6>
                </div>
                <div class="card-body">
                    <form asp-controller="ThanhToan" asp-action="Search" method="post" class="row g-3 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Số phiếu thanh toán</label>
                            <input type="text"
                                   name="sophieu"
                                   class="form-control input-custom"
                                   placeholder="Nhập số phiếu..."
                                   value="@ViewBag.SoPhieuTimKiem"
                                   required
                                   autofocus />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-search-custom w-100">
                                🔍 Tìm kiếm
                            </button>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100" style="border-radius: 6px; padding: 10px 20px; font-weight: 600;">
                                🔄 Làm mới
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông báo -->
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-@(ViewBag.MessageType ?? "info") alert-dismissible fade show" role="alert">
            @Html.Raw(ViewBag.Message)
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Kết quả -->
    @if (Model != null && Model.Count > 0)
    {
        var firstItem = Model.First();

        <!-- Form chỉnh sửa ngày -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card edit-card-custom">
                    <div class="card-header text-white">
                        <h6 class="mb-0 fw-bold">✏️ CẬP NHẬT THÔNG TIN NGÀY</h6>
                    </div>
                    <div class="card-body">
                        <!-- Thông tin phiếu -->
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <span class="form-label-custom">Số phiếu:</span><br />
                                <span class="info-badge">@firstItem.sophieu</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label-custom">Mã KCB:</span><br />
                                <span class="info-badge">@firstItem.makcb</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label-custom">Mã thanh toán:</span><br />
                                <span class="info-badge">@firstItem.mathanhtoan</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label-custom">Mã đơn thuốc:</span><br />
                                <span class="info-badge">@(firstItem.madonthuoc?.ToString() ?? "—")</span>
                            </div>
                        </div>

                        <form asp-controller="ThanhToan" asp-action="UpdateDates" method="post">
                            <input type="hidden" name="mathanhtoan" value="@firstItem.mathanhtoan" />
                            <input type="hidden" name="makcb" value="@firstItem.makcb" />
                            <input type="hidden" name="sophieu" value="@firstItem.sophieu" />
                            <input type="hidden" name="madonthuoc" value="@firstItem.madonthuoc" />

                            <div class="section-label">📅 Cập nhật ngày</div>
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label class="form-label-custom">
                                        Ngày
                                        <small class="text-muted fw-normal">(áp dụng cho thanhtoan.ngay, thanhtoan.ngaythyl, donthuoc.ngay)</small>
                                    </label>
                                    <input type="datetime-local"
                                           name="ttNgay"
                                           class="form-control"
                                           value="@firstItem.ngay?.ToString("yyyy-MM-ddTHH:mm")"
                                           required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Ngày duyệt (donthuoc.ngayduyet)</label>
                                    <input type="datetime-local"
                                           name="ngayduyet"
                                           class="form-control"
                                           value="@firstItem.ngayduyet?.ToString("yyyy-MM-ddTHH:mm")"
                                           @(firstItem.madonthuoc == null ? "disabled" : "") />
                                    @if (firstItem.madonthuoc == null)
                                    {
                                        <small class="text-muted">Không tìm thấy đơn thuốc tương ứng</small>
                                    }
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-save-custom">
                                    💾 Lưu thay đổi
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng chi tiết thanhtoanct -->
        <div class="row">
            <div class="col-12">
                <div class="card data-table-custom">
                    <div class="card-header" style="background: linear-gradient(135deg, #7b1fa2 0%, #6a1b9a 100%); border-radius: 10px 10px 0 0;">
                        <h6 class="mb-0 fw-bold text-white">📊 CHI TIẾT THANH TOÁN (thanhtoanct)</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-bordered table-custom mb-0">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width: 60px;">STT</th>
                                        <th class="text-center">Mã Thanh Toán CT</th>
                                        <th class="text-center">Thành Tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Count; i++)
                                    {
                                        <tr>
                                            <td class="text-center">@(i + 1)</td>
                                            <td class="text-center">@Model[i].mathanhtoanct</td>
                                            <td class="text-end">@Model[i].thanhtien?.ToString("N0") ₫</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer" style="background-color: #fafafa; border-top: 2px solid #e1bee7;">
                        <div class="text-center">
                            <span class="badge" style="background: linear-gradient(135deg, #ce93d8 0%, #ba68c8 100%); color: #4a148c; font-size: 13px; padding: 8px 16px; border-radius: 20px;">
                                ✅ Tổng số bản ghi: @Model.Count
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (ViewBag.Message == null)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-search" style="font-size: 4rem; color: #f48fb1;"></i>
            <p class="mt-3 fs-5">Nhập số phiếu để tra cứu thông tin thanh toán</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert-dismissible');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}

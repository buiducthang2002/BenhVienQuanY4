@model APP.Models.RaVien

<div class="container mt-5 p-4 rounded-4 shadow-sm edit-form">
    <h3 class="mb-4 text-center text-danger fw-bold">
        ✏️ CẬP NHẬT THÔNG TIN RA VIỆN
    </h3>

    <form asp-action="Edit" method="post" class="text-start">
        <div class="mb-3">
            <label class="form-label">Mã KCB</label>
            <input asp-for="makcb" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Ngày</label>
            <input asp-for="ngay" type="date" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nhận xét</label>
            <textarea asp-for="nhanxet" class="form-control" rows="2"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Phòng</label>
            <input asp-for="maphong" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Bác sĩ</label>
            <input asp-for="mabs" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Thủ trưởng</label>
            <input asp-for="thutruong" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Trưởng khoa</label>
            <input asp-for="truongkhoa" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Ghi chú</label>
            <textarea asp-for="ghichu" class="form-control" rows="2"></textarea>
        </div>

        <div class="d-flex justify-content-center gap-3 mt-4">
            <button type="submit" class="btn btn-danger btn-lg px-4">
                📂 Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn btn-outline-danger btn-lg px-4 text-white">
                ↩️ Quay lại
            </a>
        </div>
    </form>
</div>


<style>
    body {
        background-color: #fff5f7;
        font-family: 'Segoe UI', sans-serif;
    }

    .edit-form {
        background-color: #fff0f3;
        border: 1px solid #f3b8c5;
        max-width: 650px;
    }

    .text-danger {
        color: #e91e63 !important;
    }


    .form-label {
        color: #e91e63;
        font-weight: 600;
    }

    .form-control {
        border-radius: 6px;
        border: 1px solid #f3b8c5;
    }

        .form-control:focus {
            border-color: #e91e63;
            box-shadow: 0 0 0 0.15rem rgba(233, 30, 99, 0.25);
        }


    .btn-danger {
        background-color: #e91e63 !important;
        border: none;
        color: #fff !important;
        font-weight: 600;
        transition: 0.2s ease-in-out;
    }

        .btn-danger:hover {
            background-color: #c2185b !important;
        }

    .btn-outline-danger {
        background-color: #e91e63 !important;
        border: none !important;
        color: #fff !important;
        font-weight: 600;
        transition: 0.2s;
    }

        .btn-outline-danger:hover {
            background-color: #ad1457 !important;
            color: #fff !important;
        }


    .rounded-4 {
        border-radius: 12px !important;
    }

    .shadow-sm {
        box-shadow: 0 4px 12px rgba(233, 30, 99, 0.15) !important;
    }
</style>